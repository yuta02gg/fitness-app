<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-md bg-white rounded-2xl shadow p-8">
    <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">ログイン</h2>

    <% if alert.present? %>
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700">
        <p class="font-semibold">
          入力内容を確認してください
        </p>

        <p class="mt-2 text-sm">
          <%= alert %>
        </p>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-5">
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, "パスワード", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "ml-2 block text-sm text-gray-700" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "ログインする", class: "w-full rounded-lg bg-emerald-600 px-4 py-2 text-white font-semibold hover:bg-emerald-700" %>
      </div>
    <% end %>

    <div class="mt-4">
      <%= button_to "ゲストログイン", users_guest_login_path, method: :post, class: "w-full rounded-lg border border-emerald-600 px-4 py-2 text-emerald-700 font-semibold hover:bg-emerald-50" %>
    </div>

    <div class="mt-6 text-center text-sm">
      <%= link_to "Sign up", new_user_registration_path, class: "font-medium text-gray-700 hover:text-gray-900" %>
    </div>
  </div>
</div>
