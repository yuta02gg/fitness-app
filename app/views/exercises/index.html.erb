<div class="min-h-screen bg-gray-50">
  <header class="bg-white shadow">
    <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold text-gray-800">種目一覧</h1>

      <div class="flex items-center gap-4">
        <%= link_to "マイページ", mypage_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
        <%= link_to "種目を登録", new_exercise_path, class: "rounded-lg bg-emerald-600 px-4 py-2 text-white text-sm font-semibold hover:bg-emerald-700" %>
      </div>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <% if alert.present? %>
      <div class="mb-6 rounded-lg bg-red-50 px-4 py-3 text-red-700">
        <%= alert %>
      </div>
    <% end %>

    <div class="bg-white rounded-2xl shadow p-6 mb-6">
      <%= form_with url: exercises_path, method: :get, local: true, class: "flex gap-3" do |f| %>
        <%= f.text_field :keyword, value: @keyword, placeholder: "種目名で検索", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        <%= f.submit "検索", class: "rounded-lg bg-emerald-600 px-5 py-2 text-white font-semibold hover:bg-emerald-700" %>
      <% end %>
    </div>

    <% if @exercises.present? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% @exercises.each do |exercise| %>
          <div class="bg-white rounded-2xl shadow p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-lg font-bold text-gray-800"><%= exercise.name %></h2>
                <p class="mt-1 text-sm text-emerald-700 font-semibold"><%= exercise.body_part %></p>
              </div>

              <div class="flex gap-2">
                <%= link_to "編集", edit_exercise_path(exercise), class: "rounded-lg border border-gray-300 px-3 py-1 text-sm text-gray-700 hover:bg-gray-50" %>
                <%= button_to "削除", exercise_path(exercise), method: :delete, data: { turbo_confirm: "この種目を削除しますか？" }, class: "rounded-lg border border-red-300 px-3 py-1 text-sm text-red-600 hover:bg-red-50" %>
              </div>
            </div>

            <% if exercise.memo.present? %>
              <p class="mt-4 text-gray-600 whitespace-pre-wrap"><%= exercise.memo %></p>
            <% else %>
              <p class="mt-4 text-gray-400">メモはありません</p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl shadow p-8 text-center">
        <p class="text-gray-600 mb-4">登録されている種目はありません。</p>
        <%= link_to "最初の種目を登録する", new_exercise_path, class: "inline-block rounded-lg bg-emerald-600 px-5 py-2 text-white font-semibold hover:bg-emerald-700" %>
      </div>
    <% end %>
  </main>
</div>
