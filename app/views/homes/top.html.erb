<div class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Fitness App</h1>
      <p class="text-lg text-gray-600 mb-8">
        紙のトレーニングノートのように、日々の筋トレ記録を管理できるアプリです。
      </p>

      <div class="flex justify-center gap-4">
        <% if user_signed_in? %>
          <%= link_to "マイページへ", mypage_path, class: "rounded-lg bg-emerald-600 px-6 py-3 text-white font-semibold hover:bg-emerald-700" %>
        <% else %>
          <%= link_to "新規登録", new_user_registration_path, class: "rounded-lg bg-emerald-600 px-6 py-3 text-white font-semibold hover:bg-emerald-700" %>
          <%= link_to "ログイン", new_user_session_path, class: "rounded-lg border border-emerald-600 px-6 py-3 text-emerald-700 font-semibold hover:bg-emerald-50" %>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16">
      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-2">記録する</h2>
        <p class="text-gray-600">種目、重量、回数、セット数、メモを記録できます。</p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-2">見返す</h2>
        <p class="text-gray-600">過去のトレーニング記録を日付ごとに確認できます。</p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-2">続ける</h2>
        <p class="text-gray-600">日々の筋トレを継続しやすくするための記録アプリです。</p>
      </div>
    </div>
  </div>
</div>
