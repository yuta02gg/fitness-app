<div class="min-h-screen bg-gray-50">
  <header class="bg-white shadow">
    <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold text-gray-800">マイページ</h1>

      <div class="flex items-center gap-4">
        <span class="text-sm text-gray-600"><%= current_user.name %> さん</span>
        <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "rounded-lg bg-gray-800 px-4 py-2 text-white text-sm font-semibold hover:bg-gray-900" %>
      </div>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <% if notice.present? %>
      <div class="mb-6 rounded-lg bg-emerald-50 px-4 py-3 text-emerald-700">
        <%= notice %>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-6 rounded-lg bg-red-50 px-4 py-3 text-red-700">
        <%= alert %>
      </div>
    <% end %>

    <div class="bg-white rounded-2xl shadow p-6 mb-6">
      <div class="flex items-center justify-between mb-6">
        <%= link_to "前月", mypage_path(month: @current_date.prev_month.strftime("%Y-%m-01")), class: "rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>

        <h2 class="text-2xl font-bold text-gray-800">
          <%= @current_date.strftime("%Y年%m月") %>
        </h2>

        <%= link_to "翌月", mypage_path(month: @current_date.next_month.strftime("%Y-%m-01")), class: "rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
      </div>

      <div class="grid grid-cols-7 border-t border-l border-gray-200">
        <% ["日", "月", "火", "水", "木", "金", "土"].each do |day_name| %>
          <div class="bg-gray-100 border-r border-b border-gray-200 px-2 py-2 text-center text-sm font-semibold text-gray-600">
            <%= day_name %>
          </div>
        <% end %>

        <% @calendar_dates.each do |date| %>
          <% training_record = @training_records[date] %>
          <% is_current_month = date.month == @current_date.month %>
          <% is_today = date == Date.current %>

          <div class="min-h-28 border-r border-b border-gray-200 p-2 <%= is_current_month ? 'bg-white' : 'bg-gray-50' %>">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm <%= is_current_month ? 'text-gray-800' : 'text-gray-400' %> <%= is_today ? 'font-bold text-emerald-700' : '' %>">
                <%= date.day %>
              </span>

              <% if is_today %>
                <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs text-emerald-700">今日</span>
              <% end %>
            </div>

            <% if training_record.present? %>
              <%= link_to training_record_path(training_record), class: "block rounded-lg bg-emerald-50 p-2 text-sm text-emerald-800 hover:bg-emerald-100" do %>
                <p class="font-semibold">記録あり</p>
                <p class="mt-1 text-xs">
                  <%= training_record.training_sets.size %>セット
                </p>
              <% end %>
            <% elsif is_current_month %>
              <%= link_to "記録する", new_training_record_path(trained_on: date), class: "inline-block rounded-lg border border-gray-300 px-2 py-1 text-xs text-gray-600 hover:bg-gray-50" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white rounded-2xl shadow p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-2">種目管理</h3>
        <p class="text-gray-600 mb-4">トレーニング種目を登録・編集できます。</p>
        <%= link_to "種目一覧へ", exercises_path, class: "inline-block rounded-lg bg-emerald-600 px-4 py-2 text-white font-semibold hover:bg-emerald-700" %>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-2">記録管理</h3>
        <p class="text-gray-600 mb-4">日付ごとのトレーニング記録を確認できます。</p>
        <%= link_to "記録一覧へ", training_records_path, class: "inline-block rounded-lg bg-emerald-600 px-4 py-2 text-white font-semibold hover:bg-emerald-700" %>
      </div>
    </div>
  </main>
</div>
