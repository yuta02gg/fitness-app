<% if training_record.errors.any? %>
  <div class="mb-6 rounded-lg bg-red-50 px-4 py-3 text-red-700">
    <p class="font-semibold mb-2">入力内容を確認してください</p>
    <ul class="list-disc pl-5">
      <% training_record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<% if exercises.blank? %>
  <div class="rounded-lg bg-yellow-50 px-4 py-3 text-yellow-700">
    <p class="font-semibold">先に種目を登録してください。</p>
    <p class="mt-1">トレーニング記録を登録するには、種目が1件以上必要です。</p>
    <div class="mt-4">
      <%= link_to "種目を登録する", new_exercise_path, class: "inline-block rounded-lg bg-emerald-600 px-5 py-2 text-white font-semibold hover:bg-emerald-700" %>
    </div>
  </div>
<% else %>
  <%= form_with model: training_record, local: true do |f| %>
    <div class="mb-5">
      <%= f.label :trained_on, "トレーニング日", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :trained_on, class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
    </div>

    <div class="mb-6">
      <%= f.label :memo, "全体メモ", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :memo, rows: 4, placeholder: "例：胸トレ。フォームを意識した。", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
    </div>

    <div class="mb-6">
      <h2 class="text-lg font-bold text-gray-800 mb-4">セット内容</h2>

      <div class="space-y-4">
        <%= f.fields_for :training_sets do |set_form| %>
          <div class="rounded-xl border border-gray-200 p-4">
            <%= set_form.hidden_field :id %>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div>
                <%= set_form.label :exercise_id, "種目", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= set_form.collection_select :exercise_id, exercises, :id, :name, { prompt: "選択" }, class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
              </div>

              <div>
                <%= set_form.label :set_number, "セット数", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= set_form.number_field :set_number, min: 1, placeholder: "1", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
              </div>

              <div>
                <%= set_form.label :weight, "重量(kg)", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= set_form.number_field :weight, step: "0.25", min: 0, placeholder: "60", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
              </div>

              <div>
                <%= set_form.label :reps, "回数", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= set_form.number_field :reps, min: 1, placeholder: "10", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
              </div>
            </div>

            <div class="mt-4">
              <%= set_form.label :memo, "セットメモ", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= set_form.text_field :memo, placeholder: "例：少し重かった", class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
            </div>

            <% if set_form.object.persisted? %>
              <div class="mt-3 flex items-center">
                <%= set_form.check_box :_destroy, class: "h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-500" %>
                <%= set_form.label :_destroy, "このセットを削除する", class: "ml-2 text-sm text-red-600" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex gap-3">
      <%= f.submit submit_text, class: "rounded-lg bg-emerald-600 px-5 py-2 text-white font-semibold hover:bg-emerald-700" %>
      <%= link_to "キャンセル", training_records_path, class: "rounded-lg border border-gray-300 px-5 py-2 text-gray-700 font-semibold hover:bg-gray-50" %>
    </div>
  <% end %>
<% end %>
