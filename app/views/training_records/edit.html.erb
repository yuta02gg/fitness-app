<div class="min-h-screen bg-gray-50">
  <header class="bg-white shadow">
    <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold text-gray-800">トレーニング記録編集</h1>

      <%= link_to "記録詳細へ", training_record_path(@training_record), class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <div class="bg-white rounded-2xl shadow p-6">
      <%= render "form", training_record: @training_record, exercises: @exercises, submit_text: "更新する" %>
    </div>
  </main>
</div>
